// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  // directUrl only needed for migrations - optional since you're using existing databases
  // directUrl = env("DIRECT_DATABASE_URL")
}

model Note {
  id        Int      @id @default(autoincrement())
  title     String
  content   String
  createdAt DateTime @default(now())
}

model Skill {
  id          Int      @id @default(autoincrement())
  title       String
  description String
  route       String
  createdAt   DateTime @default(now())
  imageUrl    String
  imageAlt    String
}

model Signup {
  id        String   @id @default(cuid())
  firstName String
  lastName  String
  email     String   @unique
  createdAt DateTime @default(now())
}

model Form {
  id          String        @id @default(cuid())
  slug        String        @unique
  name        String
  description String?
  elements    FormElement[]
}

model FormElement {
  id           String        @id @default(cuid())
  form         Form          @relation(fields: [formId], references: [id])
  formId       String
  parent       FormElement?  @relation("FormElementChildren", fields: [parentId], references: [id])
  parentId     String?
  children     FormElement[] @relation("FormElementChildren")

  position     Int           @default(0)
  name         String
  type         String        // or an enum if you defined one
  label        String
  placeholder  String?
  heading      String?
  description  String?
  min          Float?
  max          Float?
  step         Float?
  defaultValue Json?
  rules        Json?

  options      FormOption[]
}

model FormOption {
  id        String       @id @default(cuid())
  element   FormElement  @relation(fields: [elementId], references: [id])
  elementId String

  position  Int          @default(0)
  value     String
  label     String
}